package patternProgarmming;

public class sexteenpattern {

	public static void main(String[] args) {
			
			for (int k = 1; k <= 5; k++) {
				for (int j = 1; j <= k; j++) {
					System.out.print(" ");
				}
				
			for (int j = 5; j >= k; j--) {
				System.out.print("*");
			}
			System.out.println();
		}

	}

}
